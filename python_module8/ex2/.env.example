# 演習2（Accessing the Mainframe）の設定見本。
#
# このファイルを ".env" にコピーして実際の値を入れる:
#     cp .env.example .env
#
# ".env" 自体は git で無視され、本物の秘密を絶対にコミットしない。
# 実際の環境変数はここの値より優先される。

# 'development' または 'production'
MATRIX_MODE=development

# データ保存用の接続文字列
DATABASE_URL=sqlite:///./matrix_dev.db

# 外部サービス用の秘密鍵（ここはダミー。本物の鍵は書かない）
API_KEY=replace-with-your-key

# ログの詳細度（DEBUG, INFO, WARNING, ERROR）
LOG_LEVEL=DEBUG

# レジスタンスネットワークの URL
ZION_ENDPOINT=http://localhost:8000
